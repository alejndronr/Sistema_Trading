# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Sistema de Trading Algoritmico
# Copia a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Exchange (Binance Spot) ───────────────────────────────────────────────────
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ─── Telegram ──────────────────────────────────────────────────────────────────
# 1. Crea un bot con @BotFather -> obtendras el token
# 2. Tu ID numerico: usa @userinfobot en Telegram
TELEGRAM_TOKEN=tu_bot_token_de_botfather
TELEGRAM_CHAT_ID=tu_id_numerico_de_telegram
TELEGRAM_ALLOWED_USER_ID=tu_id_numerico_de_telegram   # igual que TELEGRAM_CHAT_ID

# ─── Base de datos ─────────────────────────────────────────────────────────────
# PostgreSQL en produccion (deploy.sh lo genera automaticamente)
DATABASE_URL=postgresql://trading_user:password@127.0.0.1:5432/trading_db
# SQLite para desarrollo local:
# DATABASE_URL=sqlite:///data/db/trading.db

# ─── Modo de operacion (DOS CAPAS INDEPENDIENTES) ──────────────────────────────
#
# PAPER_MODE=true es el alias de compatibilidad que activa ambas capas de seguridad.
# Para mayor control, usar las dos flags independientes:
#
#   SIMULATE_DATA=true/false
#     true  -> NO hace llamadas reales a la API de Binance para datos de mercado
#              (solo para tests unitarios, NO es el modo paper normal)
#     false -> Usa datos reales de Binance (precios reales, sin testnet)
#              ESTO ES LO NORMAL EN PAPER TRADING
#
#   SEND_REAL_ORDERS=true/false
#     true  -> Envia ordenes reales a Binance (LIVE TRADING -- NO USAR AUN)
#     false -> Simula ordenes en paper portfolio local (PAPER TRADING)
#
# Combinaciones:
#   SIMULATE_DATA=false + SEND_REAL_ORDERS=false  -> Paper Trading normal (recomendado)
#   SIMULATE_DATA=false + SEND_REAL_ORDERS=true   -> LIVE TRADING (NO activar sin validacion)
#   SIMULATE_DATA=true  + SEND_REAL_ORDERS=false  -> Solo tests sin datos reales
#
# PAPER_MODE=true sobreescribe ambas flags al modo paper seguro.
# SIEMPRE mantener true hasta completar 4 semanas de paper trading sin anomalias.
PAPER_MODE=true

# Flags individuales (solo si quieres control granular -- requiere PAPER_MODE=false o ausente)
# SIMULATE_DATA=false
# SEND_REAL_ORDERS=false

# --- Margin Trading ---
# Habilita shorts en altcoins (requiere cuenta Cross Margin en Binance)
# LEER DISCLAIMER.md ANTES DE ACTIVAR
MARGIN_ENABLED=false

# ─── Sistema ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=production          # development | production
INITIAL_CAPITAL=300.0
