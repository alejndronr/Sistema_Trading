# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Sistema de Trading Algorítmico
# Copia a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Exchange (Binance Spot) ───────────────────────────────────────────────────
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ─── Telegram ──────────────────────────────────────────────────────────────────
# 1. Crea un bot con @BotFather → obtendrás el token
# 2. Tu ID numérico: usa @userinfobot en Telegram
TELEGRAM_TOKEN=tu_bot_token_de_botfather
TELEGRAM_CHAT_ID=tu_id_numerico_de_telegram
TELEGRAM_ALLOWED_USER_ID=tu_id_numerico_de_telegram   # igual que TELEGRAM_CHAT_ID

# ─── Base de datos ─────────────────────────────────────────────────────────────
# PostgreSQL en producción (deploy.sh lo genera automáticamente)
DATABASE_URL=postgresql://trading_user:password@localhost:5432/trading_db
# SQLite para desarrollo local:
# DATABASE_URL=sqlite:///data/db/trading.db

# ─── Modo de operación ─────────────────────────────────────────────────────────
# SIEMPRE true hasta validar 4 semanas de paper trading sin pérdidas anómalas
PAPER_MODE=true

# ─── Sistema ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=production          # development | production
INITIAL_CAPITAL=300.0
